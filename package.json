{
  "name": "@simonrueba/tripwire",
  "version": "0.1.0",
  "description": "Context injection for AI agents, triggered by the codebase itself",
  "type": "module",
  "bin": {
    "tripwire": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./engine": "./dist/engine/index.js",
    "./server": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/"
  },
  "keywords": [
    "mcp",
    "ai",
    "context",
    "tripwire",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "micromatch": "^4.0.8",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
